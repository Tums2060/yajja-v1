generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  CUSTOMER
  RIDER
  VENDOR
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  name         String?
  email        String   @unique
  phone        String   @unique
  passwordHash String
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}